# MIKE Messenger — Environment Variables
# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mike_messenger?retryWrites=true&w=majority

# JWT secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry
JWT_EXPIRE=30d

# Frontend URL (for CORS — update for production)
CLIENT_URL=http://localhost:3000

# File upload settings
MAX_FILE_SIZE=10485760

# Encryption key for E2E simulation (32 chars)
ENCRYPTION_KEY=mike_messenger_encryption_key_32c
